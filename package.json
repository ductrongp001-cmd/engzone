{
  "name": "engzone-desktop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:electron\"",
    "dev:server": "cd server && npx tsx src/index.ts",
    "dev:electron": "electron electron/main.cjs",
    "build": "cd client && npm run build",
    "start": "npm run build && electron electron/main.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0"
  }
}
